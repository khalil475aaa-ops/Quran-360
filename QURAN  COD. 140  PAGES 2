// ==================== SEARCH SCREEN ====================

class SearchScreen extends StatefulWidget {
  const SearchScreen({super.key});

  @override
  State<SearchScreen> createState() => _SearchScreenState();
}

class _SearchScreenState extends State<SearchScreen> {
  final TextEditingController _searchController = TextEditingController();
  final QuranService _quranService = QuranService();
  final HadithService _hadithService = HadithService();
  
  List<Map<String, dynamic>> _results = [];
  bool _isSearching = false;
  String _selectedFilter = 'All';

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('تلاش'),
        bottom: PreferredSize(
          preferredSize: const Size.fromHeight(100),
          child: Padding(
            padding: const EdgeInsets.all(16),
            child: Column(
              children: [
                TextField(
                  controller: _searchController,
                  decoration: InputDecoration(
                    hintText: 'قرآن یا حدیث میں تلاش کریں...',
                    prefixIcon: const Icon(Icons.search),
                    border: OutlineInputBorder(borderRadius: BorderRadius.circular(30)),
                    filled: true,
                    fillColor: Colors.white,
                  ),
                  onSubmitted: (value) => _performSearch(value),
                ),
                const SizedBox(height: 8),
                SingleChildScrollView(
                  scrollDirection: Axis.horizontal,
                  child: Row(
                    children: [
                      _buildFilterChip('All', 'سب'),
                      _buildFilterChip('Quran', 'قرآن'),
                      _buildFilterChip('Hadith', 'حدیث'),
                    ],
                  ),
                ),
              ],
            ),
          ),
        ),
      ),
      body: _isSearching
          ? const Center(child: CircularProgressIndicator())
          : _results.isEmpty
              ? Center(
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Icon(Icons.search_off, size: 64, color: Colors.grey.shade400),
                      const SizedBox(height: 16),
                      Text(
                        _searchController.text.isEmpty ? 'کچھ تلاش کریں' : 'کوئی نتیجہ نہیں ملا',
                        style: TextStyle(color: Colors.grey.shade600),
                      ),
                    ],
                  ),
                )
              : ListView.builder(
                  padding: const EdgeInsets.all(16),
                  itemCount: _results.length,
                  itemBuilder: (context, index) {
                    final result = _results[index];
                    return Card(
                      margin: const EdgeInsets.only(bottom: 8),
                      child: ListTile(
                        leading: CircleAvatar(
                          backgroundColor: result['type'] == 'quran'
                              ? AppColors.primaryGreen.withOpacity(0.1)
                              : AppColors.accentBlue.withOpacity(0.1),
                          child: Icon(
                            result['type'] == 'quran' ? Icons.menu_book : Icons.book,
                            color: result['type'] == 'quran' ? AppColors.primaryGreen : AppColors.accentBlue,
                            size: 20,
                          ),
                        ),
                        title: Text(
                          result['type'] == 'quran'
                              ? 'سورۃ ${result['surah']} : آیت ${result['ayah']}'
                              : result['book'],
                          style: const TextStyle(fontWeight: FontWeight.bold),
                        ),
                        subtitle: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: [
                            Text(
                              result['text'] ?? result['arabic'] ?? '',
                              style: const TextStyle(fontSize: 14),
                              maxLines: 2,
                            ),
                            if (result['translation'] != null)
                              Text(
                                result['translation'],
                                style: TextStyle(color: AppColors.textSecondary, fontSize: 12),
                                maxLines: 2,
                              ),
                          ],
                        ),
                        trailing: const Icon(Icons.arrow_forward_ios, size: 16),
                        onTap: () {},
                      ),
                    );
                  },
                ),
    );
  }

  Widget _buildFilterChip(String value, String label) {
    return Padding(
      padding: const EdgeInsets.only(right: 8),
      child: FilterChip(
        label: Text(label),
        selected: _selectedFilter == value,
        onSelected: (selected) {
          setState(() {
            _selectedFilter = value;
            if (_searchController.text.isNotEmpty) {
              _performSearch(_searchController.text);
            }
          });
        },
        backgroundColor: Colors.grey.shade200,
        selectedColor: AppColors.primaryGreen,
        labelStyle: TextStyle(
          color: _selectedFilter == value ? Colors.white : Colors.black,
        ),
      ),
    );
  }

  void _performSearch(String query) {
    if (query.isEmpty) return;

    setState(() => _isSearching = true);

    Future.delayed(const Duration(milliseconds: 500), () {
      final results = <Map<String, dynamic>>[];

      if (_selectedFilter != 'Hadith') {
        results.addAll([
          {
            'type': 'quran',
            'surah': 1,
            'ayah': 1,
            'text': 'بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ',
            'translation': 'اللہ کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے',
          },
          {
            'type': 'quran',
            'surah': 2,
            'ayah': 255,
            'text': 'اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ',
            'translation': 'اللہ کے سوا کوئی معبود نہیں، وہ زندہ اور سب کا تھامنے والا ہے',
          },
        ]);
      }

      if (_selectedFilter != 'Quran') {
        results.addAll([
          {
            'type': 'hadith',
            'book': 'صحیح بخاری',
            'number': 1,
            'arabic': 'إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ',
            'translation': 'اعمال کا دارومدار نیتوں پر ہے',
          },
        ]);
      }

      setState(() {
        _results = results;
        _isSearching = false;
      });
    });
  }

  @override
  void dispose() {
    _searchController.dispose();
    super.dispose();
  }
}