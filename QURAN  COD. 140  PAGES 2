// ==================== AYAH MODEL ====================

class AyahModel {
  final int surahNumber;
  final int ayahNumber;
  final String arabicText;
  final int pageNumber;
  final int juzNumber;
  final int rukuNumber;
  final bool isSajda;
  final Map<String, String> translations;
  final Map<String, String> tafseer;

  AyahModel({
    required this.surahNumber,
    required this.ayahNumber,
    required this.arabicText,
    required this.pageNumber,
    required this.juzNumber,
    required this.rukuNumber,
    required this.isSajda,
    required this.translations,
    required this.tafseer,
  });

  String getTranslation(String translator) {
    return translations[translator] ?? '';
  }

  String getTafseer(String mufassir) {
    return tafseer[mufassir] ?? '';
  }

  bool isValid() {
    if (surahNumber < 1 || surahNumber > 114) return false;
    if (ayahNumber < 1) return false;
    if (arabicText.isEmpty) return false;
    if (pageNumber < 1 || pageNumber > 604) return false;
    if (juzNumber < 1 || juzNumber > 30) return false;
    return true;
  }

  factory AyahModel.fromJson(Map<String, dynamic> json) {
    return AyahModel(
      surahNumber: json['surah'] ?? 0,
      ayahNumber: json['ayah'] ?? 0,
      arabicText: json['text'] ?? '',
      pageNumber: json['page'] ?? 1,
      juzNumber: json['juz'] ?? 1,
      rukuNumber: json['ruku'] ?? 1,
      isSajda: json['sajda'] ?? false,
      translations: Map<String, String>.from(json['translations'] ?? {}),
      tafseer: Map<String, String>.from(json['tafseer'] ?? {}),
    );
  }
}

