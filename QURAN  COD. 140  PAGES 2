  }

  List<HadithModel> searchInHadith(String query) {
    final results = <HadithModel>[];
    final lowercaseQuery = query.toLowerCase();

    for (var hadith in _hadithData) {
      if (hadith.arabicText.contains(query)) {
        results.add(hadith);
        continue;
      }
      if (hadith.urduTranslation.toLowerCase().contains(lowercaseQuery)) {
        results.add(hadith);
        continue;
      }
      if (hadith.englishTranslation.toLowerCase().contains(lowercaseQuery)) {
        results.add(hadith);
        continue;
      }
      if (results.length >= 100) break;
    }
    return results;
  }

  List<HadithModel> getByGrade(String grade) {
    return _hadithData.where((hadith) => hadith.grade.contains(grade)).toList();
  }
}

// ==================== PRAYER TIMES SERVICE ====================

class PrayerTimesService {
  Future<Position?> getCurrentLocation() async {
    bool serviceEnabled = await Geolocator.isLocationServiceEnabled();
    if (!serviceEnabled) return null;

    LocationPermission permission = await Geolocator.checkPermission();
    if (permission == LocationPermission.denied) {
      permission = await Geolocator.requestPermission();
      if (permission == LocationPermission.denied) return null;
    }
    if (permission == LocationPermission.deniedForever) return null;

    return await Geolocator.getCurrentPosition();
  }

  Map<String, String> getDummyPrayerTimes() {
    return {
      'Fajr': '5:12 AM',
      'Sunrise': '6:45 AM',
      'Dhuhr': '12:30 PM',
      'Asr': '3:45 PM',
      'Maghrib': '6:15 PM',
      'Isha': '7:30 PM',
      'Midnight': '12:00 AM',
    };
  }

  String formatTime(String time) {
    if (time.contains('AM') || time.contains('PM')) return time;
    
    final parts = time.split(':');
    if (parts.length != 2) return time;
    
    int hour = int.parse(parts[0]);
    int minute = int.parse(parts[1]);
    
    String period = hour >= 12 ? 'PM' : 'AM';
    hour = hour > 12 ? hour - 12 : hour;
    hour = hour == 0 ? 12 : hour;
    
    return '${hour.toString().padLeft(2, '0')}:${minute.toString().padLeft(2, '0')} $period';
  }

  Map<String, dynamic> getNextPrayer(Map<String, String> timings) {
    final now = DateTime.now();
    final currentTime = '${now.hour.toString().padLeft(2, '0')}:${now.minute.toString().padLeft(2, '0')}';
    
    final prayers = [
      {'name': 'Fajr', 'time': timings['Fajr']},
      {'name': 'Dhuhr', 'time': timings['Dhuhr']},
      {'name': 'Asr', 'time': timings['Asr']},
      {'name': 'Maghrib', 'time': timings['Maghrib']},
      {'name': 'Isha', 'time': timings['Isha']},
    ];
    
    for (var prayer in prayers) {
      if (prayer['time'].toString().compareTo(currentTime) > 0) {
        return prayer;
      }
    }
    return prayers.first;
  }
}

// ==================== QIBLA SERVICE ====================

class QiblaService {
  static const double makkahLatitude = 21.4225;
  static const double makkahLongitude = 39.8262;

  double calculateQiblaDirection(double currentLat, double currentLng) {
    final lat1 = _degreesToRadians(currentLat);
    final lng1 = _degreesToRadians(currentLng);
    final lat2 = _degreesToRadians(makkahLatitude);
    final lng2 = _degreesToRadians(makkahLongitude);

    final deltaLng = lng2 - lng1;
    
    final y = sin(deltaLng) * cos(lat2);
    final x = cos(lat1) * sin(lat2) - sin(lat1) * cos(lat2) * cos(deltaLng);
    
    var qiblaDirection = atan2(y, x);
    qiblaDirection = _radiansToDegrees(qiblaDirection);
    
    return (qiblaDirection + 360) % 360;
  }

  Stream<double> getDeviceHeading() {
    return magnetometerEvents.map((event) {
      final x = event.x;
      final y = event.y;
      var heading = atan2(y, x) * (180 / pi);
      return (heading + 360) % 360;
    });
  }

  double getQiblaOffset(double deviceHeading, double qiblaDirection) {
    var offset = qiblaDirection - deviceHeading;
    offset = (offset + 360) % 360;
    if (offset > 180) offset = offset - 360;
    return offset;
  }

  bool isPointingToQibla(double deviceHeading, double qiblaDirection, double tolerance) {
    final offset = getQiblaOffset(deviceHeading, qiblaDirection);
    return offset.abs() <= tolerance;
  }

  double _degreesToRadians(double degrees) => degrees * pi / 180;
  double _radiansToDegrees(double radians) => radians * 180 / pi;
}

// ==================== AUDIO SERVICE ====================

class AudioService {
  final AudioPlayer _player = AudioPlayer();
  bool isPlaying = false;
  String currentAudio = '';

  Future<void> playAudio(String url) async {
    try {
      await _player.play(UrlSource(url));
      isPlaying = true;
      currentAudio = url;
    } catch (e) {
      print('Error playing audio: $e');
    }
  }

  Future<void> pauseAudio() async {
    await _player.pause();
    isPlaying = false;
  }

  Future<void> stopAudio() async {
    await _player.stop();
    isPlaying = false;
    currentAudio = '';
  }

  Future<void> repeatAudio() async {
    if (currentAudio.isNotEmpty) {
      await _player.seek(Duration.zero);
      await _player.resume();
    }
  }

  void dispose() {
    _player.dispose();
  }
}

