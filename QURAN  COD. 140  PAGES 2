// ==================== QURAN SERVICE ====================

class QuranService {
  List<AyahModel> _quranData = [];

  AyahModel? getAyah(int surahNumber, int ayahNumber) {
    try {
      return _quranData.firstWhere(
        (ayah) => ayah.surahNumber == surahNumber && ayah.ayahNumber == ayahNumber,
      );
    } catch (e) {
      return null;
    }
  }

  List<AyahModel> getSurah(int surahNumber) {
    return _quranData
        .where((ayah) => ayah.surahNumber == surahNumber)
        .toList()
      ..sort((a, b) => a.ayahNumber.compareTo(b.ayahNumber));
  }

  Future<Map<String, dynamic>?> getRandomAyah() async {
    try {
      final random = Random();
      final randomSurah = random.nextInt(114) + 1;
      
      final surahAyahs = getSurah(randomSurah);
      if (surahAyahs.isEmpty) return null;
      
      final randomAyah = random.nextInt(surahAyahs.length);
      final ayah = surahAyahs[randomAyah];
      
      return {
        'surah': ayah.surahNumber,
        'ayah': ayah.ayahNumber,
        'arabic': ayah.arabicText,
        'translation': ayah.getTranslation('junagarhi'),
      };
    } catch (e) {
      return null;
    }
  }

  List<Map<String, dynamic>> searchInQuran(String query) {
    final results = <Map<String, dynamic>>[];
    final lowercaseQuery = query.toLowerCase();
    
    for (var ayah in _quranData) {
      if (ayah.arabicText.contains(query)) {
        results.add({
          'type': 'quran',
          'surah': ayah.surahNumber,
          'ayah': ayah.ayahNumber,
          'text': ayah.arabicText,
          'translation': ayah.getTranslation('junagarhi'),
        });
        continue;
      }
      
      for (var translation in ayah.translations.values) {
        if (translation.toLowerCase().contains(lowercaseQuery)) {
          results.add({
            'type': 'quran',
            'surah': ayah.surahNumber,
            'ayah': ayah.ayahNumber,
            'text': ayah.arabicText,
            'translation': ayah.getTranslation('junagarhi'),
          });
          break;
        }
      }
      
      if (results.length >= 100) break;
    }
    
    return results;
  }

  bool validateQuranData() {
    if (_quranData.length != AppConstants.totalAyahs) {
      return false;
    }
    return true;
  }
}

